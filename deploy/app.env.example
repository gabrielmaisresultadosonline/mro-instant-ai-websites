# Runtime env for the MRO.BIO app container.
# Copy to deploy/app.env and fill in the real values from Lovable Cloud → Connectors → Supabase.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Same values, exposed to the browser bundle:
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# MRO.BIO admin panel (login at /administracao)
ADMIN_EMAIL=mro@gmail.com
ADMIN_PASSWORD=change-me-strong
ADMIN_JWT_SECRET=generate-a-64-char-random-string

# Kiwify webhook — OBRIGATÓRIO para receber compras
# Use o mesmo valor que você configurou na URL do webhook na Kiwify:
#   https://mro.bio/api/public/webhooks/kiwify?token=<KIWIFY_WEBHOOK_TOKEN>
KIWIFY_WEBHOOK_TOKEN=troque-por-um-token-secreto-forte

# URL pública usada nos e-mails (links de ativação, renovação etc.)
PUBLIC_BASE_URL=https://mro.bio

# SMTP Hostinger (opcional — já tem fallback embutido)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=suporte@mro.bio
# SMTP_PASS=
# SMTP_FROM="MRO.bio" <suporte@mro.bio>

# Optional: Lovable AI fallback (unused unless you wire it)
# LOVABLE_API_KEY=
