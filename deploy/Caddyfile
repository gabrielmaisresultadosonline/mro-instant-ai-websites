{
	email {$ADMIN_EMAIL_CERT}
	on_demand_tls {
		ask http://app:3000/api/public/cert-check
	}
}

# ---- Apex + www: serve the MRO.BIO app (landing, dashboard, admin) ----
mro.bio, www.mro.bio {
	encode zstd gzip
	reverse_proxy app:3000
}

# ---- Subdomínios <slug>.mro.bio: SSL on-demand via HTTP-01 ----
:443 {
	tls {
		on_demand
	}
	encode zstd gzip

	@sub header_regexp slug Host ^([a-z0-9][a-z0-9-]{1,28}[a-z0-9])\.mro\.bio$

	handle @sub {
		rewrite * /api/public/site/{re.slug.1}{uri}
		reverse_proxy app:3000
	}

	handle {
		redir https://mro.bio{uri}
	}
}
